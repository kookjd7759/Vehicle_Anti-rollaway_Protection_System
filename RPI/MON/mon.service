[Unit]
Description=VAPS MON Program
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/mon_program
Environment=MON_WEB_HOST=0.0.0.0
Environment=MON_WEB_PORT=5000
Environment=MON_SERIAL_ENABLED=1
Environment=MON_SERIAL_PORT=/dev/serial0
Environment=MON_SERIAL_BAUDRATE=115200
ExecStart=/usr/bin/python3 /home/pi/mon_program/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
